# Path to your Obsidian vault root.
# Copy this file to .env and set the path for your vault.
# Both `npm run dev` (watch) and `npm run build` (production) will automatically
# deploy the plugin to: <VAULT_PATH>/.obsidian/plugins/noveltools/
#
# Example (macOS):
VAULT_PATH=/Users/austen/code/The-Two-Flat-Cats
