{
  "name": "noveltools",
  "publisher": "arcades-ltd",
  "displayName": "NovelTools",
  "description": "Long-form writing: scene stitching, manuscript sidebar, word counts",
  "version": "1.1.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arcadesys/NovelTools.git"
  },
  "bugs": {
    "url": "https://github.com/Arcadesys/NovelTools/issues"
  },
  "homepage": "https://github.com/Arcadesys/NovelTools#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:noveltools.manuscript",
    "onView:noveltools.sceneCards",
    "onCommand:noveltools.openSidebar",
    "onCommand:noveltools.openSceneOutline",
    "onCommand:noveltools.openStitchedManuscript",
    "onCommand:noveltools.openProjectYaml",
    "onCommand:noveltools.buildProjectYaml",
    "onCommand:noveltools.convertLongformToProjectYaml",
    "onCommand:noveltools.showQuickStart",
    "onCommand:noveltools.openSettings"
  ],
  "contributes": {
    "configuration": {
      "title": "NovelTools",
      "properties": {
        "noveltools.projectFile": {
          "type": "string",
          "default": "noveltools.json",
          "description": "Project JSON filename (or path relative to workspace root)."
        },
        "noveltools.sceneFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Fallback: ordered scene paths when no project file. Overrides glob if set."
        },
        "noveltools.sceneGlob": {
          "type": "string",
          "default": "**/*.md",
          "description": "Fallback: glob when no project file and sceneFiles empty; one flat chapter."
        },
        "noveltools.chapterGrouping": {
          "type": "string",
          "default": "flat",
          "enum": [
            "flat",
            "folder"
          ],
          "description": "When building from files (no project YAML), group scenes into chapters by folder or keep a single flat chapter."
        },
        "noveltools.indexYamlGlob": {
          "type": "string",
          "default": "**/*[iI]ndex*.{yaml,yml,YAML,YML,md,MD}",
          "description": "Glob to discover index/manuscript files (Longform and NovelTools). Matches Index.YAML, index.yaml, Index.md, etc. Use archive/**/*[iI]ndex*.{yaml,yml,YAML,YML,md,MD} to restrict to a folder."
        },
        "noveltools.wordCount.stripMarkdown": {
          "type": "boolean",
          "default": false,
          "description": "If true, strip markdown before counting words."
        },
        "noveltools.wordCount.manuscriptScope": {
          "type": "string",
          "default": "project",
          "enum": [
            "project",
            "workspace"
          ],
          "description": "Use project YAML scene list; or 'workspace' to count all .md in workspace."
        },
        "noveltools.chapterContextPath": {
          "type": "string",
          "default": ".cursor/noveltools-chapter-context.md",
          "description": "Path (relative to workspace root) where \"Set Chapter as Context\" writes the stitched chapter for agent review. Create a Cursor rule or @-mention this file in chat."
        },
        "noveltools.stitched.sceneHeadingMode": {
          "type": "string",
          "default": "fileName",
          "enum": [
            "fileName",
            "sceneNumber",
            "none"
          ],
          "enumDescriptions": [
            "Use each markdown filename (pretty-printed) as the scene heading text.",
            "Use generic scene headings like \"Scene 1\" instead of filenames.",
            "Show numbered markdown headings only (for example: \"### 1.1\") with no scene title text."
          ],
          "description": "Controls scene heading text in stitched manuscript/chapter/selection output."
        }
      }
    },
    "commands": [
      {
        "command": "noveltools.nextScene",
        "title": "NovelTools: Next Scene"
      },
      {
        "command": "noveltools.previousScene",
        "title": "NovelTools: Previous Scene"
      },
      {
        "command": "noveltools.goToScene",
        "title": "NovelTools: Go to Scene…"
      },
      {
        "command": "noveltools.nextChapter",
        "title": "NovelTools: Next Chapter"
      },
      {
        "command": "noveltools.previousChapter",
        "title": "NovelTools: Previous Chapter"
      },
      {
        "command": "noveltools.goToChapter",
        "title": "NovelTools: Go to Chapter…"
      },
      {
        "command": "noveltools.moveChapterUp",
        "title": "NovelTools: Move Chapter Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "noveltools.moveChapterDown",
        "title": "NovelTools: Move Chapter Down",
        "icon": "$(arrow-down)"
      },
      {
        "command": "noveltools.renameChapter",
        "title": "NovelTools: Rename Chapter…"
      },
      {
        "command": "noveltools.moveSceneUp",
        "title": "NovelTools: Move Scene Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "noveltools.moveSceneDown",
        "title": "NovelTools: Move Scene Down",
        "icon": "$(arrow-down)"
      },
      {
        "command": "noveltools.addSceneAbove",
        "title": "NovelTools: Add Scene Above",
        "icon": "$(add)"
      },
      {
        "command": "noveltools.addSceneBelow",
        "title": "NovelTools: Add Scene Below",
        "icon": "$(add)"
      },
      {
        "command": "noveltools.addChapter",
        "title": "NovelTools: Add Chapter",
        "icon": "$(add)"
      },
      {
        "command": "noveltools.addChapterAbove",
        "title": "NovelTools: Add Chapter Above",
        "icon": "$(add)"
      },
      {
        "command": "noveltools.addChapterBelow",
        "title": "NovelTools: Add Chapter Below",
        "icon": "$(add)"
      },
      {
        "command": "noveltools.renameScene",
        "title": "NovelTools: Rename Scene File…"
      },
      {
        "command": "noveltools.removeScene",
        "title": "NovelTools: Remove Scene from Manuscript",
        "icon": "$(trash)"
      },
      {
        "command": "noveltools.deleteScene",
        "title": "NovelTools: Delete Scene",
        "icon": "$(trash)"
      },
      {
        "command": "noveltools.removeChapter",
        "title": "NovelTools: Remove Chapter from Manuscript",
        "icon": "$(trash)"
      },
      {
        "command": "noveltools.setSectionStatus",
        "title": "NovelTools: Set section status…"
      },
      {
        "command": "noveltools.setSectionStatusDone",
        "title": "Set status: Done (complete)",
        "icon": "$(pass-filled)"
      },
      {
        "command": "noveltools.setSectionStatusDrafted",
        "title": "Set status: Drafted",
        "icon": "$(pencil)"
      },
      {
        "command": "noveltools.setSectionStatusSpiked",
        "title": "Set status: Spiked out",
        "icon": "$(circle-slash)"
      },
      {
        "command": "noveltools.clearSectionStatus",
        "title": "Clear section status",
        "icon": "$(clear)"
      },
      {
        "command": "noveltools.openStitchedManuscript",
        "title": "NovelTools: Open Stitched Manuscript",
        "icon": "$(book)"
      },
      {
        "command": "noveltools.openStitchedChapter",
        "title": "NovelTools: Open Stitched Chapter"
      },
      {
        "command": "noveltools.openStitchedSelection",
        "title": "NovelTools: Open Stitched Selection",
        "icon": "$(combine)"
      },
      {
        "command": "noveltools.setChapterAsContext",
        "title": "NovelTools: Set Chapter as Context"
      },
      {
        "command": "noveltools.refreshManuscript",
        "title": "NovelTools: Refresh Manuscript View",
        "icon": "$(refresh)"
      },
      {
        "command": "noveltools.buildProjectYaml",
        "title": "NovelTools: Build Project YAML",
        "icon": "$(new-file)"
      },
      {
        "command": "noveltools.convertLongformToProjectYaml",
        "title": "NovelTools: Convert Longform to Project",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "noveltools.convertProjectToJson",
        "title": "NovelTools: Convert Project to JSON",
        "icon": "$(file-code)"
      },
      {
        "command": "noveltools.openProjectYaml",
        "title": "NovelTools: Open Project File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "noveltools.openSettings",
        "title": "NovelTools: Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "noveltools.showQuickStart",
        "title": "NovelTools: Quick Start",
        "icon": "$(question)"
      },
      {
        "command": "noveltools.selectDocument",
        "title": "NovelTools: Select Document",
        "icon": "$(file-directory)"
      },
      {
        "command": "noveltools.openSceneOutline",
        "title": "NovelTools: Open Scene Outline",
        "icon": "$(list-tree)"
      },
      {
        "command": "noveltools.openSidebar",
        "title": "NovelTools: Focus Sidebar",
        "icon": "$(list-tree)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "noveltools",
          "title": "NovelTools",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "noveltools": [
        {
          "id": "noveltools.manuscript",
          "name": "Manuscript"
        },
        {
          "id": "noveltools.sceneCards",
          "name": "Scene Cards"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "noveltools.manuscript",
        "contents": "# Welcome to NovelTools\n\nVersion: **v1.1.2**\n\nThe **scene outline** (chapters and scenes) opens in the **editor** area, not here.\n\n- $(list-tree) [Open Scene Outline](command:noveltools.openSceneOutline) — opens the outline in an editor tab\n- $(book) [Open Stitched Manuscript](command:noveltools.openStitchedManuscript)\n- $(go-to-file) [Open Project File](command:noveltools.openProjectYaml)\n- $(new-file) [Build Project YAML](command:noveltools.buildProjectYaml)\n- $(file-symlink-file) [Convert Longform to Project](command:noveltools.convertLongformToProjectYaml)\n\nIn the outline you can expand/collapse chapters, click scenes to open them, and use the toolbar for Refresh, Open Project File, and Open Stitched.\n\n[Quick Start Guide](command:noveltools.showQuickStart) | [Settings](command:noveltools.openSettings)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "noveltools.openProjectYaml",
          "when": "view == noveltools.manuscript",
          "group": "navigation@1"
        },
        {
          "command": "noveltools.openStitchedManuscript",
          "when": "view == noveltools.manuscript && noveltools.hasScenes",
          "group": "navigation@2"
        },
        {
          "command": "noveltools.openStitchedSelection",
          "when": "view == noveltools.manuscript && noveltools.hasScenes",
          "group": "navigation@3"
        },
        {
          "command": "noveltools.refreshManuscript",
          "when": "view == noveltools.manuscript",
          "group": "navigation@3"
        },
        {
          "command": "noveltools.addChapter",
          "when": "view == noveltools.manuscript",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "noveltools.moveChapterUp",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "navigation"
        },
        {
          "command": "noveltools.moveChapterDown",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "navigation"
        },
        {
          "command": "noveltools.addChapterAbove",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "inline@0"
        },
        {
          "command": "noveltools.addChapterBelow",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "inline@0"
        },
        {
          "command": "noveltools.renameChapter",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "navigation"
        },
        {
          "command": "noveltools.openStitchedChapter",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "navigation"
        },
        {
          "command": "noveltools.setChapterAsContext",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "navigation"
        },
        {
          "command": "noveltools.setSectionStatusDone",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "status@0"
        },
        {
          "command": "noveltools.setSectionStatusDrafted",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "status@0"
        },
        {
          "command": "noveltools.setSectionStatusSpiked",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "status@0"
        },
        {
          "command": "noveltools.clearSectionStatus",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "status@0"
        },
        {
          "command": "noveltools.addSceneAbove",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "inline@0"
        },
        {
          "command": "noveltools.addSceneBelow",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "inline@0"
        },
        {
          "command": "noveltools.moveSceneUp",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "navigation@1"
        },
        {
          "command": "noveltools.moveSceneDown",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "navigation@1"
        },
        {
          "command": "noveltools.openStitchedSelection",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "navigation@1"
        },
        {
          "command": "noveltools.renameScene",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "navigation@1"
        },
        {
          "command": "noveltools.removeScene",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "navigation@1"
        },
        {
          "command": "noveltools.deleteScene",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "navigation@1"
        },
        {
          "command": "noveltools.removeChapter",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev": "npm run compile",
    "package": "npm run compile && npx vsce package",
    "test": "npm run compile && node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.x",
    "@types/vscode": "^1.74.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "glob": "^13.0.1",
    "minimatch": "^10.1.2",
    "mocha": "^11.7.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "yaml": "^2.3.0"
  }
}
