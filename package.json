{
  "name": "noveltools",
  "displayName": "NovelTools",
  "description": "Long-form writing: scene stitching, manuscript sidebar, typewriter sounds, word counts",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:markdown",
    "onView:noveltools.manuscript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "NovelTools",
      "properties": {
        "noveltools.projectFile": {
          "type": "string",
          "default": "noveltools.yaml",
          "description": "Project YAML filename (or path relative to workspace root)."
        },
        "noveltools.sceneFiles": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Fallback: ordered scene paths when no project file. Overrides glob if set."
        },
        "noveltools.sceneGlob": {
          "type": "string",
          "default": "**/*.md",
          "description": "Fallback: glob when no project file and sceneFiles empty; one flat chapter."
        },
        "noveltools.chapterGrouping": {
          "type": "string",
          "default": "flat",
          "enum": ["flat", "folder"],
          "description": "When building from files (no project YAML), group scenes into chapters by folder or keep a single flat chapter."
        },
        "noveltools.typewriterSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable typewriter sound on keypress."
        },
        "noveltools.typewriterSound.volume": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Volume for typewriter sound (0-1)."
        },
        "noveltools.typewriterSound.path": {
          "type": "string",
          "default": "",
          "description": "Optional custom WAV path (resource path)."
        },
        "noveltools.wordCount.stripMarkdown": {
          "type": "boolean",
          "default": false,
          "description": "If true, strip markdown before counting words."
        },
        "noveltools.wordCount.manuscriptScope": {
          "type": "string",
          "default": "project",
          "enum": ["project", "workspace"],
          "description": "Use project YAML scene list; or 'workspace' to count all .md in workspace."
        }
      }
    },
    "commands": [
      { "command": "noveltools.nextScene", "title": "NovelTools: Next Scene" },
      { "command": "noveltools.previousScene", "title": "NovelTools: Previous Scene" },
      { "command": "noveltools.goToScene", "title": "NovelTools: Go to Scene…" },
      { "command": "noveltools.nextChapter", "title": "NovelTools: Next Chapter" },
      { "command": "noveltools.previousChapter", "title": "NovelTools: Previous Chapter" },
      { "command": "noveltools.goToChapter", "title": "NovelTools: Go to Chapter…" },
      { "command": "noveltools.moveChapterUp", "title": "NovelTools: Move Chapter Up" },
      { "command": "noveltools.moveChapterDown", "title": "NovelTools: Move Chapter Down" },
      { "command": "noveltools.moveSceneUp", "title": "NovelTools: Move Scene Up" },
      { "command": "noveltools.moveSceneDown", "title": "NovelTools: Move Scene Down" },
      { "command": "noveltools.openStitchedManuscript", "title": "NovelTools: Open Stitched Manuscript", "icon": "$(book)" },
      { "command": "noveltools.refreshManuscript", "title": "NovelTools: Refresh Manuscript View", "icon": "$(refresh)" },
      { "command": "noveltools.buildProjectYaml", "title": "NovelTools: Build Project YAML", "icon": "$(new-file)" },
      { "command": "noveltools.openProjectYaml", "title": "NovelTools: Open Project YAML", "icon": "$(go-to-file)" },
      { "command": "noveltools.openSettings", "title": "NovelTools: Open Settings", "icon": "$(settings-gear)" },
      { "command": "noveltools.showQuickStart", "title": "NovelTools: Quick Start", "icon": "$(question)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "noveltools",
          "title": "NovelTools",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "noveltools": [
        {
          "id": "noveltools.manuscript",
          "name": "Manuscript"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "noveltools.manuscript",
        "contents": "# Welcome to NovelTools\n\nGet started quickly:\n\n- [Build Project YAML](command:noveltools.buildProjectYaml)\n- [Open Project YAML](command:noveltools.openProjectYaml)\n- [Open Stitched Manuscript](command:noveltools.openStitchedManuscript)\n\nHow it works:\n\n- The Manuscript view mirrors `noveltools.yaml`.\n- Drag chapters/scenes to reorder; the YAML updates automatically.\n- Use the toolbar buttons above for common actions.\n\n[Quick Start Guide](command:noveltools.showQuickStart) | [Settings](command:noveltools.openSettings)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "noveltools.showQuickStart",
          "when": "view == noveltools.manuscript",
          "group": "navigation@1"
        },
        {
          "command": "noveltools.openProjectYaml",
          "when": "view == noveltools.manuscript && noveltools.hasProjectFile",
          "group": "navigation@2"
        },
        {
          "command": "noveltools.buildProjectYaml",
          "when": "view == noveltools.manuscript && !noveltools.hasProjectFile",
          "group": "navigation@2"
        },
        {
          "command": "noveltools.openStitchedManuscript",
          "when": "view == noveltools.manuscript && noveltools.hasScenes",
          "group": "navigation@3"
        },
        {
          "command": "noveltools.refreshManuscript",
          "when": "view == noveltools.manuscript",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "noveltools.moveChapterUp",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "navigation"
        },
        {
          "command": "noveltools.moveChapterDown",
          "when": "view == noveltools.manuscript && viewItem == chapter",
          "group": "navigation"
        },
        {
          "command": "noveltools.moveSceneUp",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "navigation"
        },
        {
          "command": "noveltools.moveSceneDown",
          "when": "view == noveltools.manuscript && viewItem == scene",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev": "npm run compile",
    "package": "npm run compile && npx vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.x",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "yaml": "^2.3.0"
  }
}
